# machine-specific config written by setup.sh
.env
# cloud creds (CRITIC_API_KEY etc.) — never commit
cloud.env
# per-run critic log (pin+log)
critique.log
# per-machine capability registry (planted-defect probe results)
critic_registry.tsv
# per-machine remembered panel (the user's chosen 1-3 critics, written by --configure)
critic_panel.json
# macOS
.DS_Store
# private project notes (Claude meta) — not part of the published framework
CLAUDE.md
# process / planning artifacts (binding inputs, ANALYSIS / SELF_REVIEW / VERIFICATION / PROJECT_LOG) — not part of the published framework
docs/
# Jekyll build output (generated by a local `jekyll build`; the site is built by GitHub Pages)
_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/
